// Benchmark 13: HashMap build and query
function hashmap_build_query(n: int) -> number {
    var m = HashMap()
    var i = 0
    while i < n {
        m = m.set(i, i * 2.5)
        i = i + 1
    }
    var sum = 0.0
    i = 0
    while i < n {
        let v = m.get(i)
        if v != none {
            sum = sum + v
        }
        i = i + 1
    }
    return sum
}
print(hashmap_build_query(100000))
