// Benchmark 10: Count primes by trial division
function is_prime(n: int) -> int {
    if n < 2 { return 0; }
    if n < 4 { return 1; }
    if n % 2 == 0 { return 0; }
    var d = 3;
    while d * d <= n {
        if n % d == 0 { return 0; }
        d = d + 2;
    }
    return 1;
}

function count_primes(limit: int) -> int {
    var count = 0;
    var n = 2;
    while n < limit {
        count = count + is_prime(n);
        n = n + 1;
    }
    return count;
}
print(count_primes(10000000))
