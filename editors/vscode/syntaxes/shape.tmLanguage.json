{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Shape",
  "scopeName": "source.shape",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.shape",
          "match": "//.*$"
        },
        {
          "name": "comment.block.shape",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.shape",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.interpolated.triple.shape",
          "begin": "f\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.interpolated.shape",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.content.shape",
          "begin": "c\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.double.shape",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        }
      ]
    },
    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.shape",
          "match": "\\\\[\\\\\"nrt0{}]"
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.shape",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.shape" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.shape" }
          },
          "patterns": [
            { "include": "source.shape" }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.shape",
          "match": "(@)(\\w+)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.shape" },
            "2": { "name": "entity.name.annotation.shape" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.shape",
          "match": "\\b(if|else|then|while|for|loop|return|break|continue|match|when|where)\\b"
        },
        {
          "name": "keyword.declaration.shape",
          "match": "\\b(let|var|const|fn|function|type|trait|interface|enum|impl|extend|method|pub|mod|module)\\b"
        },
        {
          "name": "keyword.control.import.shape",
          "match": "\\b(import|from|use|as|export)\\b"
        },
        {
          "name": "keyword.control.async.shape",
          "match": "\\b(async|await)\\b"
        },
        {
          "name": "keyword.other.shape",
          "match": "\\b(comptime|stream|test|it|dyn|typeof|instanceof|self|in|and|or|not|recursive|select|order|by|group|join|on|alert|datasource|query|optimize|assert|expect|should|setup|teardown|config|within|over|partition|pattern|find)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.shape",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.shape",
          "match": "\\b(none)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.shape",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.shape",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.shape",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.decimal-suffix.shape",
          "match": "\\b[0-9][0-9_]*\\.?[0-9_]*d\\b"
        },
        {
          "name": "constant.numeric.percentage.shape",
          "match": "\\b[0-9][0-9_]*\\.?[0-9_]*%"
        },
        {
          "name": "constant.numeric.float.shape",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.float.scientific.shape",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.shape",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.shape",
          "match": "\\b(int|number|bool|string|decimal|bigint|Array|HashMap|Option|Result|DateTime|Content|Some)\\b"
        },
        {
          "name": "entity.name.type.shape",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.shape",
          "match": "\\b(fn|function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.shape" },
            "2": { "name": "entity.name.function.shape" }
          }
        },
        {
          "name": "meta.function.definition.shape",
          "match": "\\b(method)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.shape" },
            "2": { "name": "entity.name.function.shape" }
          }
        },
        {
          "name": "meta.function.call.shape",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.shape" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.shape",
          "match": "=>|->|\\|>"
        },
        {
          "name": "keyword.operator.misc.shape",
          "match": "\\?\\?|!!|\\?\\.|\\.\\.\\.|\\.\\.|\\.\\.=|::"
        },
        {
          "name": "keyword.operator.comparison.shape",
          "match": "==|!=|<=|>=|~=|~<|~>|<|>"
        },
        {
          "name": "keyword.operator.assignment.compound.shape",
          "match": "\\*\\*=|<<=|>>=|\\+=|-=|\\*=|/=|%=|\\^=|&=|\\|="
        },
        {
          "name": "keyword.operator.assignment.shape",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.shape",
          "match": "\\*\\*|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.shape",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.shape",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.ternary.shape",
          "match": "\\?|:"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.round.shape",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.square.shape",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.bracket.curly.shape",
          "match": "[{}]"
        },
        {
          "name": "punctuation.bracket.angle.shape",
          "match": "[<>]"
        },
        {
          "name": "punctuation.separator.comma.shape",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.shape",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.shape",
          "match": "\\."
        }
      ]
    }
  }
}
