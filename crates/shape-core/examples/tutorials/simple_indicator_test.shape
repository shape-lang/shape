// @skip - Uses REPL commands (:data) and advanced features not yet in stdlib
# Simple test without modules to verify basic functionality

# Define ATR inline for now
function atr_simple(period) {
    # Simplified ATR - just using high-low range
    let sum = 0.0;
    for i in range(0, period) {
        sum = sum + (data[-i].high - data[-i].low);
    }
    return sum / period;
}

# Load data
