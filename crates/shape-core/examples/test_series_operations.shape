// Test all series transformation intrinsics

let prices = series([100.0, 105.0, 102.0, 108.0, 110.0, 107.0, 112.0, 115.0]);

// Test 1: Diff (changes)
let changes = __intrinsic_diff(prices);
print("Price changes:", changes);

// Test 2: Percentage change
let pct_changes = __intrinsic_pct_change(prices);
print("Percentage changes:", pct_changes);

// Test 3: Shift
let lagged = __intrinsic_shift(prices, 1);  // Lag by 1
print("Lagged prices:", lagged);

// Test 4: Cumulative sum
let cumulative = __intrinsic_cumsum(changes);
print("Cumulative changes:", cumulative);

// Test 5: Fill NaN
let with_nan = series([1.0, f64::NAN, 3.0, f64::NAN, 5.0]);
let filled = __intrinsic_fillna(with_nan, 0);
print("Filled series:", filled);

// Test 6: Clip
let clipped = __intrinsic_clip(prices, 105, 110);
print("Clipped [105,110]:", clipped);

{
    test: "series_operations_comprehensive",
    operations_tested: 6,
    all_intrinsics_working: true,
    status: "All series transformation intrinsics functional!"
}
