// Test assignment expressions

// Const variables
const PI = 3.14159

// Var variables can be reassigned
var counter = 0
counter = counter + 1
counter = counter + 1

// Let variables can be reassigned
let sum = 0
sum = sum + 10
sum = sum + 20

// Use variables in expressions
let circumference = 2 * PI * 5
let average = sum / 2

// Simple pattern without variables
pattern high_volume {
    data[0].volume > 1000 and
    data[0].close > data[0].open * 1.8
}

// Find patterns
find high_volume last(10 candles)