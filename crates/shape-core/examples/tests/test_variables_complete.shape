// Comprehensive variable test

// Const variables
const PI = 3.14159
const THRESHOLD = 0.8

// Var variables can be reassigned
var counter = 0
counter = counter + 1
counter = counter + 1

// Let variables can be reassigned
let sum = 0
sum = sum + 10
sum = sum + 20

// Use variables in expressions
let circumference = 2 * PI * 5
let average = sum / 2

// Variables in patterns
pattern high_volume {
    data[0].volume > 1000 and
    data[0].close > data[0].open * (1 + THRESHOLD)
}

// Find patterns
find high_volume last(10 candles)