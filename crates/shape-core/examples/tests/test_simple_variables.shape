// Test simple variable declarations in Shape

// Basic variable declarations
let x = 10
var y = 20
const z = 30

// With type annotations
let price: number = 100.5
var trend: string = "bullish"
const threshold: number = 0.8

// Using variables in expressions
let avg = (x + y + z) / 3
let isAboveThreshold = price > threshold

// Using variables in pattern
pattern test_pattern {
    data[0].close > threshold and
    data[0].volume > 1000
}

// Query using the pattern
find test_pattern last(10 candles)