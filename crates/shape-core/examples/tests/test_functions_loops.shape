// Function with multiple statements
function find_trend_strength(period) {
    let fast_ma = sma(10);
    let slow_ma = sma(period);
    
    // Calculate trend strength
    let diff = fast_ma - slow_ma;
    let strength = diff / slow_ma * 100;
    
    // Return the strength value
    return strength;
}

