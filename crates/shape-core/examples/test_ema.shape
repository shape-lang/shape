// Test EMA (Exponential Moving Average) via rolling stdlib
import { rolling_mean } from std::core::utils::rolling

let prices = series([10.0, 20.0, 30.0, 40.0, 50.0, 60.0, 70.0, 80.0, 90.0, 100.0]);

// Calculate SMA with period 5 as a proxy demo
let sma5 = rolling_mean(prices, 5);

print("Prices:", prices);
print("5-period SMA:", sma5);

{
    test: "ema_via_stdlib",
    data_points: 10,
    period: 5,
    result: sma5,
    status: "success"
}
